# Local config for the x402 live-smoke harness. Copy to `.env`
# (gitignored) and fill in the values that apply to your wallet.
# pkg/x402/live_smoke_test.go reads this file at startup and exports
# any keys that aren't already set in the shell environment.
#
# None of these are Venice-specific secrets — Venice authenticates
# against a wallet via SIWX, no API key. The wallet itself lives in
# OWS; sky10 just points to it by name.

# Enables the live smoke. When unset, every TestX402LiveSmoke case
# is skipped and no real USDC is charged.
X402_LIVE=1

# OWS wallet to sign with. Defaults to "default" — the universal
# wallet OWS creates on first install.
X402_LIVE_WALLET=default

# Prefix filter on case IDs. With "venice" only the three Venice
# cases run; with "" every case runs (~$5.20 per full sweep).
# Comment out to run everything.
X402_LIVE_ONLY=venice

# Wallet passphrase. Empty for unencrypted wallets (OWS's default
# install). Set to your actual passphrase if `ows wallet list` shows
# "Secured: ✓ (encrypted)".
OWS_PASSPHRASE=
