# sky10 web env example.
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Copy this to web/.env.local and fill values for local dev.

# Vite dev-server proxy target for /rpc and /health. Defaults to the local
# sky10 daemon on http://localhost:9101 if unset.
SKY10_WEB_RPC_TARGET=

# Base URL of the separate Sky10 broker backend that handles "Connect Google"
# and proxies allowed Google tool calls. See:
#   docs/google-agent-auth-client-plan.md
#   docs/google-agent-auth-backend-prompt.md
# Leave unset until the broker is deployed; the integrations UI shows a
# clear "not configured" state in that case.
VITE_SKY10_API_URL=
