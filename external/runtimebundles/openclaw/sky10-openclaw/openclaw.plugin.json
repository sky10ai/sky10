{
  "id": "sky10",
  "channels": [
    "sky10"
  ],
  "name": "Sky10 Channel",
  "version": "0.1.0",
  "description": "Connect OpenClaw agents to the sky10 P2P network",
  "configSchema": {
    "type": "object",
    "properties": {
      "rpcUrl": {
        "type": "string",
        "default": "http://localhost:9101",
        "description": "Sky10 daemon RPC URL"
      },
      "agentName": {
        "type": "string",
        "description": "Name to register as on the sky10 network"
      },
      "skills": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["code", "shell", "browser", "web-search", "file-ops"],
        "description": "Skills to advertise on the sky10 network"
      },
      "gatewayUrl": {
        "type": "string",
        "default": "http://localhost:18789",
        "description": "OpenClaw gateway HTTP URL"
      },
      "gatewayToken": {
        "type": "string",
        "description": "Gateway API bearer token (if auth is enabled)"
      }
    },
    "required": ["agentName"]
  }
}
